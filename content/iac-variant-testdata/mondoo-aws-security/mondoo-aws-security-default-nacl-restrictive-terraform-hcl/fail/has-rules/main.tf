# Non-compliant: default network ACL defines permissive ingress and egress rules.
resource "aws_default_network_acl" "fail_example" {
  default_network_acl_id = "acl-12345678"

  ingress {
    protocol   = -1
    rule_no    = 100
    action     = "allow"
    cidr_block = "0.0.0.0/0"
    from_port  = 0
    to_port    = 0
  }

  egress {
    protocol   = -1
    rule_no    = 100
    action     = "allow"
    cidr_block = "0.0.0.0/0"
    from_port  = 0
    to_port    = 0
  }
}
