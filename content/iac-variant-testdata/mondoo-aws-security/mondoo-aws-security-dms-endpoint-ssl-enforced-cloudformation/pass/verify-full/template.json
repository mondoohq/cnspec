{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Resources": {
    "MyEndpoint": {
      "Type": "AWS::DMS::Endpoint",
      "Properties": {
        "EndpointType": "source",
        "EngineName": "mysql",
        "ServerName": "db.example.com",
        "Port": 3306,
        "DatabaseName": "mydb",
        "SslMode": "verify-full"
      }
    }
  }
}
