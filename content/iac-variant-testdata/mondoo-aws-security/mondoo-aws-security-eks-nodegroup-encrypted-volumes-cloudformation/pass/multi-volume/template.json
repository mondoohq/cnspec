{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Resources": {
    "NodeLaunchTemplate": {
      "Type": "AWS::EC2::LaunchTemplate",
      "Properties": {
        "LaunchTemplateName": "eks-node-lt",
        "LaunchTemplateData": {
          "InstanceType": "t3.large",
          "BlockDeviceMappings": [
            {
              "DeviceName": "/dev/xvda",
              "Ebs": { "VolumeSize": 20, "Encrypted": true }
            },
            {
              "DeviceName": "/dev/xvdb",
              "Ebs": { "VolumeSize": 100, "Encrypted": true }
            }
          ]
        }
      }
    }
  }
}
