{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Resources": {
    "ServiceSecurityGroup": {
      "Type": "AWS::EC2::SecurityGroup",
      "Properties": {
        "GroupDescription": "RDP access from internal network",
        "VpcId": "vpc-0abc1234def567890",
        "SecurityGroupIngress": [
          {
            "IpProtocol": "tcp",
            "FromPort": 3389,
            "ToPort": 3389,
            "CidrIp": "172.16.0.0/12"
          }
        ]
      }
    }
  }
}
