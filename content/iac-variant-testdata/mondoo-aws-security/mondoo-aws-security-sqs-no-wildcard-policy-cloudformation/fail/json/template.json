{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Resources": {
    "MyQueuePolicy": {
      "Type": "AWS::SQS::QueuePolicy",
      "Properties": {
        "Queues": ["https://sqs.us-east-1.amazonaws.com/123456789012/my-queue"],
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Sid": "AllowPublic",
              "Effect": "Allow",
              "Principal": "*",
              "Action": "sqs:SendMessage",
              "Resource": "arn:aws:sqs:us-east-1:123456789012:my-queue"
            }
          ]
        }
      }
    }
  }
}
